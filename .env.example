# Database
DATABASE_PATH=./data/rik.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=rik
MINIO_ROOT_PASSWORD=riksecret

# LLM (OpenAI-compatible API)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b

# IMAP (email polling)
# Default: Stalwart from docker-compose. Swap for Gmail/Outlook/any IMAP.
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USER=rik@localhost
IMAP_PASS=rik
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL=300000

# CalDAV (optional — for agenda sync)
# CALDAV_URL=
# CALDAV_USERNAME=
# CALDAV_PASSWORD=
